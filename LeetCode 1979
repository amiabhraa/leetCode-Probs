class Solution {
    public int findGCD(int[] nums) {
        int numSmall =nums[0];
        int numBig = nums[0];
        int num =0;
        for(int i = 0; i< nums.length; i++){
            if(i > numBig){
                numBig = i;
            }
            if(i < numSmall){
                numSmall = i;
            }
        }
        
    }
}
